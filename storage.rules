
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read and write a file in the 'cvs' folder
    // ONLY if the filename exactly matches their own user ID plus the .pdf extension.
    match /cvs/{fileName} {
      allow read, write: if request.auth != null && fileName == request.auth.uid + '.pdf';
    }
  }
}
